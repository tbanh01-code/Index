{
  "version": 2,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/redirect", "destination": "/redirect.html" },
        { "source": "/redirect",    "destination": "/redirect.html"    },
    { "source": "/",         "destination": "/index.html"    },
    { "source": "/:path((?!.*\\.).*)",         "destination": "/index.html"    }
  ]
}
